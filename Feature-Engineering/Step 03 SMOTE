

```python
# ── Cell 1: Create imbalanced dataset ──────────────────────────
from sklearn.datasets import make_classification

X, y = make_classification(
    n_samples=1000,
    n_redundant=0,
    n_features=2,
    n_clusters_per_class=1,
    weights=[0.90],
    random_state=12
)

# ── Cell 2: Build DataFrame ─────────────────────────────────────
import pandas as pd

df1 = pd.DataFrame(X, columns=['f1', 'f2'])
df2 = pd.DataFrame(y, columns=['target'])
final_df = pd.concat([df1, df2], axis=1)
final_df.head()

# ── Cell 3: Check class imbalance ───────────────────────────────
final_df['target'].value_counts()
# 0 → 900
# 1 → 100

# ── Cell 4: Visualize imbalanced data ───────────────────────────
import matplotlib.pyplot as plt

plt.scatter(final_df['f1'], final_df['f2'], c=final_df['target'])
plt.title("Before SMOTE (Imbalanced)")
plt.show()

# ── Cell 5: Install & import SMOTE ──────────────────────────────
# !pip install imbalanced-learn
from imblearn.over_sampling import SMOTE   # ← note: over_sampling not oversampling

# ── Cell 6: Apply SMOTE ─────────────────────────────────────────
oversample = SMOTE()
X, y = oversample.fit_resample(final_df[['f1', 'f2']], final_df['target'])

print(X.shape)  # (1800, 2)
print(y.shape)  # (1800,)

# ── Cell 7: Verify balance ──────────────────────────────────────
print(len(y[y == 0]))  # 900
print(len(y[y == 1]))  # 900

# ── Cell 8: Visualize balanced data ─────────────────────────────
df1 = pd.DataFrame(X, columns=['f1', 'f2'])
df2 = pd.DataFrame(y, columns=['target'])
oversample_df = pd.concat([df1, df2], axis=1)

plt.scatter(oversample_df['f1'], oversample_df['f2'], c=oversample_df['target'])
plt.title("After SMOTE (Balanced)")
plt.show()
```

